#!/bin/bash
#SBATCH -N 1
#SBATCH -n 32
#SBATCH --mem=8g
#SBATCH -t 24:00:00

OMP_NUM_THREADS=1

. ../pipeline.source

conda activate bowtie-samtools

echo $1 $2

for i in `ls ${2}/*.fna`
do
    echo ${i::-4}
    bowtie2 -x ${i::-4} -1 ../EXTRACTs/${2}/FASTQs/$1_R1.fastq.gz -2 ../EXTRACTs/${2}/FASTQs/$1_R2.fastq.gz \
	    -S /dev/null -p 32 2>&1 | grep overall
done

conda deactivate
